# SentinelSecure Environment Configuration Template
# Copy this file to .env and fill in with your actual credentials
# WARNING: NEVER commit .env to version control!

# Grafana Admin Credentials
GF_SECURITY_ADMIN_PASSWORD=ChangeMeToStrongPassword123

# Wazuh Indexer (OpenSearch) Configuration
INDEXER_URL=https://127.0.0.1:9200
INDEXER_USERNAME=admin
INDEXER_PASSWORD=ChangeMeToStrongPassword456

# Wazuh API Credentials
API_USERNAME=wazuh-wui
API_PASSWORD=ChangeMeToStrongPassword789

# Wazuh Dashboard Configuration
DASHBOARD_USERNAME=kibanaserver
DASHBOARD_PASSWORD=ChangeMeToStrongPassword012

# Filebeat SSL Configuration
FILEBEAT_SSL_VERIFICATION_MODE=full
SSL_CERTIFICATE_AUTHORITIES=/etc/ssl/root-ca.pem
SSL_CERTIFICATE=/etc/ssl/filebeat.pem
SSL_KEY=/etc/ssl/filebeat.key

# Loki Configuration
LOKI_URL=http://loki:3100/loki/api/v1/push

# Prometheus Configuration
PROMETHEUS_RETENTION=15d
PROMETHEUS_SCRAPE_INTERVAL=15s

# Bitdefender Webhook Integration
BITDEFENDER_API_KEY=your_bitdefender_api_key_here

# LogSentinel API Configuration
LOGSENTINEL_API_KEY=your_logsentinel_api_key_here
LOGSENTINEL_ORGANIZATION_ID=your_org_id_here

# MySQL Database (if using)
DB_HOST=mysql
DB_PORT=3306
DB_USER=grafana_user
DB_PASSWORD=ChangeMeToStrongPassword345
DB_NAME=grafana_alerts

# Email Alerting (optional)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_FROM=alerts@example.com
SMTP_USERNAME=your_email@example.com
SMTP_PASSWORD=your_app_password_here

# Slack Integration (optional)
SLACK_AUTH_TOKEN=xoxb-your-slack-token-here
SLACK_ALERT_CHANNEL=#security-alerts

# Timezone
TZ=UTC

# Debug Mode (set to 'true' only for development)
DEBUG=false
