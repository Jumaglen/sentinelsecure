# Auto detect text files and normalize line endings to LF
* text=auto

# Source code
*.py text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.sh text eol=lf
*.bash text eol=lf

# Shell scripts
*.sh eol=lf

# Configuration files
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.xml text eol=lf
*.toml text eol=lf
*.config text eol=lf
*.conf text eol=lf
Dockerfile text eol=lf

# Documentation
*.md text eol=lf
*.txt text eol=lf
*.rst text eol=lf

# Ignore certain files for diff
*.lock diff=lockfile

# Binary files
*.gz binary
*.zip binary
*.tar binary
*.7z binary
*.jpg binary
*.jpeg binary
*.png binary
*.gif binary
*.ico binary
*.mov binary
*.mp4 binary
*.mp3 binary
*.flv binary
*.fla binary
*.swf binary

# Database
*.db binary
*.sqlite binary
*.sqlite3 binary

# Wazuh certificates - treat as binary
*.pem binary
*.key binary
*.crt binary
*.pfx binary
*.p12 binary
